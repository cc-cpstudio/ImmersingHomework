<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ImmersingHomework.Views.WelcomePages.LicensePage">
    <StackPanel Orientation="Vertical" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBox x:Name="LicenseTextBox"  Height="600" IsReadOnly="True" TextWrapping="Wrap"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBlock Text="点击“下一步”即代表您同意该许可。" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </StackPanel>
</UserControl>
