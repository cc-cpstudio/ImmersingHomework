<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ImmersingHomework.Views.WelcomePages.SubjectPage">
    <StackPanel Orientation="Vertical" Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Text="科目设置" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Text="添加一些常用的科目，方便后续管理作业。" FontSize="16" HorizontalAlignment="Center"/>
        <Grid RowDefinitions="Auto,*" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="8" MinWidth="400">
            <Button Grid.Row="0" Grid.Column="1" Content="添加科目" Click="AddSubjectButton_OnClick"/>
            <ScrollViewer Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" MaxHeight="200">
                <WrapPanel x:Name="SubjectPanel" ItemSpacing="8" LineSpacing="8"/>
            </ScrollViewer>
        </Grid>
    </StackPanel>
</UserControl>
