<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ImmersingHomework.Controls.HomeworkPanel">
    <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" AllowAutoHide="True">
            <StackPanel x:Name="SubjectHomeworkPanels" Orientation="Horizontal" Spacing="32" />
        </ScrollViewer>
        <TextBlock x:Name="NoHomeworkText" Text="今天没有作业，休息一下吧！" 
                   FontSize="24" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
                   Foreground="Gray"
                   IsVisible="False"/>
    </Grid>
</UserControl>
